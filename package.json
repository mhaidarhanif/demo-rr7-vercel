{
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development bun ./dev-server.js",
    "build": "react-router build && node vercel/prepare.js",
    "typecheck": "react-router typegen && tsc",
    "docker:up": "docker compose up -d",
    "docker:up:prod": "docker compose -f docker-compose.prod.yaml up -d",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:gen": "prisma generate --no-hints",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio"
  },
  "prisma": {
    "seed": "bun prisma/seed.ts"
  },
  "dependencies": {
    "@epic-web/remember": "^1.1.0",
    "@prisma/client": "^6.2.1",
    "@react-router/express": "^7.1.1",
    "@react-router/node": "^7.1.1",
    "@vercel/node": "^3.2.29",
    "express": "^4.21.2",
    "isbot": "^5.1.21",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.1.1"
  },
  "devDependencies": {
    "@react-router/dev": "^7.1.1",
    "@types/express": "^5.0.0",
    "@types/node": "^20.17.12",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "eslint": "^9.18.0",
    "postcss": "8.4.49",
    "prisma": "^6.2.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
