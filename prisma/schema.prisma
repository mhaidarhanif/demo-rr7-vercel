generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@prisma/client-generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Animal {
  id String @id @default(cuid())

  slug      String   @unique
  name      String
  species   String
  isAdopted Boolean  @default(false)
  birthdate DateTime
}
